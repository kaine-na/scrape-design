# Copy this file to .env.local, then fill in your provider settings.

# OpenAI-compatible API key.
LLM_API_KEY=

# OpenAI-compatible chat completions base URL. Must NOT include /chat/completions.
# RECOMMENDED FOR SPEED (fastest -> slower):
# - Groq: https://api.groq.com/openai/v1 (300-935 TPS, <2s total)
# - Gemini: https://generativelanguage.googleapis.com/v1beta/openai (32-199 TPS)
# - DeepSeek: https://api.deepseek.com (cheapest, 9-20s)
# - OpenAI: https://api.openai.com/v1
# - OpenRouter: https://openrouter.ai/api/v1
LLM_BASE_URL=https://api.openai.com/v1

# Model name exactly as your provider expects it.
# RECOMMENDED FAST MODELS:
# - Groq: llama-3.3-70b-versatile, mixtral-8x7b-32768
# - Gemini: gemini-2.0-flash, gemini-1.5-flash
# - DeepSeek: deepseek-chat (v3)
# - OpenAI: gpt-4o-mini
# - OpenRouter: openai/gpt-4o-mini, google/gemini-2.0-flash-001
LLM_MODEL=gpt-4o-mini

# Generation controls.
# Lower temperature = faster + more consistent output.
LLM_TEMPERATURE=0.2
# Reduce max tokens for faster generation (2500-3000 is plenty for DESIGN.md).
LLM_MAX_TOKENS=3000
# Timeout: 60s is realistic with optimized prompts.
LLM_TIMEOUT_MS=120000
LLM_STREAM=true

# Analyzer: 20s timeout with resource blocking is sufficient.
ANALYSIS_TIMEOUT_MS=20000

# Rate limiting.
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000
