# Copy this file to .env.local, then fill in your provider settings.
# The current app still uses the mock provider until the real LLM adapter is wired.

# OpenAI-compatible API key.
# Examples:
# - OpenAI: sk-...
# - OpenRouter: sk-or-...
# - Groq/Together/Fireworks/etc: use the key from your provider dashboard.
LLM_API_KEY=

# OpenAI-compatible chat completions base URL. Must NOT include /chat/completions.
# Examples:
# - OpenAI: https://api.openai.com/v1
# - OpenRouter: https://openrouter.ai/api/v1
# - Groq: https://api.groq.com/openai/v1
# - Together AI: https://api.together.xyz/v1
# - Fireworks: https://api.fireworks.ai/inference/v1
LLM_BASE_URL=https://api.openai.com/v1

# Model name exactly as your provider expects it.
# Examples:
# - OpenAI: gpt-4.1-mini, gpt-4o-mini
# - OpenRouter: openai/gpt-4.1-mini, anthropic/claude-3.5-sonnet
# - Groq: llama-3.3-70b-versatile
LLM_MODEL=gpt-4.1-mini

# Optional generation controls for the real LLM adapter.
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4000
LLM_TIMEOUT_MS=180000
LLM_STREAM=true

# Analyzer limits.
ANALYSIS_TIMEOUT_MS=30000

# Public free-tool abuse protection.
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000
